<nav class="breadcrumbs" aria-label="Breadcrumb">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/"},
      {% if tags | getBeat %}
      {"@type": "ListItem", "position": 2, "name": "{{ tags | getBeat | capitalize }}", "item": "{{ site.url }}/{{ tags | getBeat }}/"},
      {"@type": "ListItem", "position": 3, "name": "{{ title }}", "item": "{{ site.url }}{{ page.url }}"}
      {% else %}
      {"@type": "ListItem", "position": 2, "name": "{{ title }}", "item": "{{ site.url }}{{ page.url }}"}
      {% endif %}
    ]
  }
  </script>
  <ol class="breadcrumb-list">
    <li><a href="/">Home</a></li>
    {% if tags | getBeat %}
    <li><a href="/{{ tags | getBeat }}/">{{ tags | getBeat | capitalize }}</a></li>
    {% endif %}
    <li aria-current="page">{{ title }}</li>
  </ol>
  <a href="/{{ tags | getBeat if tags else '' }}/" class="breadcrumb-back">&larr; Back to {{ tags | getBeat | capitalize if tags else 'Home' }}</a>
</nav>