<div class="newsletter-signup hidden">
  <h3>Get the Daily Briefing</h3>
  <p>The kratom industry briefing, in your inbox every morning.</p>
  <form class="newsletter-form" action="https://a.klaviyo.com/client/subscriptions/" method="post" data-company-id="{{ klaviyo.publicApiKey }}" data-list-id="{{ klaviyo.listId }}">
    <label for="newsletter-email" class="sr-only">Email address</label>
    <input type="email" name="email" id="newsletter-email" placeholder="your@email.com" required>
    <button type="submit">Subscribe</button>
  </form>
  <p class="newsletter-status" aria-live="polite"></p>
</div>