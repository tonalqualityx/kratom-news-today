<div class="share-buttons">
  <span class="share-label">Share</span>
  <a href="https://twitter.com/intent/tweet?url={{ site.url }}{{ page.url | urlencode }}&text={{ title | urlencode }}" target="_blank" rel="noopener" aria-label="Share on X">X</a>
  <a href="https://www.facebook.com/sharer/sharer.php?u={{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener" aria-label="Share on Facebook">Facebook</a>
  <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url | urlencode }}" target="_blank" rel="noopener" aria-label="Share on LinkedIn">LinkedIn</a>
  <a href="https://www.reddit.com/submit?url={{ site.url }}{{ page.url | urlencode }}&title={{ title | urlencode }}" target="_blank" rel="noopener" aria-label="Share on Reddit">Reddit</a>
  <button class="copy-link" data-url="{{ site.url }}{{ page.url }}" aria-label="Copy link">Copy link</button>
</div>