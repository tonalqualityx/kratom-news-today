{% if sources and sources.length > 0 %}
<section class="sources">
  <h3>Sources</h3>
  <ul class="sources-list">
    {% for source in sources %}
    <li class="source-item">
      <a href="{{ source.url }}" target="_blank" rel="noopener" class="source-title">{{ source.title }}</a>
      <span class="source-publisher">{{ source.publisher }}</span>
      {% if source.published %}
      <time class="source-date">{{ source.published }}</time>
      {% endif %}
      {% if source.excerpt %}
      <p class="source-excerpt">{{ source.excerpt }}</p>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}